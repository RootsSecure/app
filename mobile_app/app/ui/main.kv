#:import dp kivy.metrics.dp

<LoginScreen>:
    name: "login"
    BoxLayout:
        orientation: "vertical"
        padding: dp(24)
        spacing: dp(12)

        Label:
            text: "NRI Plot Sentinel"
            font_size: "24sp"
            bold: True
            size_hint_y: None
            height: self.texture_size[1] + dp(8)

        Label:
            text: "Secure sign-in for field monitoring"
            color: 0.6, 0.6, 0.6, 1
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        TextInput:
            id: email_input
            hint_text: "Email"
            multiline: False
            write_tab: False
            size_hint_y: None
            height: dp(44)

        TextInput:
            id: password_input
            hint_text: "Password"
            multiline: False
            password: True
            write_tab: False
            size_hint_y: None
            height: dp(44)

        Button:
            text: "Sign In"
            size_hint_y: None
            height: dp(44)
            on_release: app.login(email_input.text, password_input.text)

        Label:
            text: root.status_text
            color: 0.85, 0.25, 0.25, 1 if root.status_text.startswith("Login failed") else (0.25, 0.65, 0.3, 1)
            text_size: self.width, None
            halign: "left"
            valign: "top"
            size_hint_y: None
            height: max(self.texture_size[1], dp(24))

        Widget:

<HomeScreen>:
    name: "home"
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(12)

        Label:
            text: "Operations Dashboard"
            font_size: "22sp"
            bold: True
            size_hint_y: None
            height: self.texture_size[1] + dp(6)

        GridLayout:
            cols: 2
            spacing: dp(8)
            size_hint_y: None
            height: self.minimum_height

            Label:
                text: "Properties"
                halign: "left"
                text_size: self.size
            Label:
                text: str(root.property_count)
                halign: "right"
                text_size: self.size

            Label:
                text: "Active alerts"
                halign: "left"
                text_size: self.size
            Label:
                text: str(root.active_alerts)
                halign: "right"
                text_size: self.size

            Label:
                text: "Online devices"
                halign: "left"
                text_size: self.size
            Label:
                text: str(root.online_devices)
                halign: "right"
                text_size: self.size

            Label:
                text: "Offline queue"
                halign: "left"
                text_size: self.size
            Label:
                text: str(root.queue_size)
                halign: "right"
                text_size: self.size

            Label:
                text: "Last sync"
                halign: "left"
                text_size: self.size
            Label:
                text: root.last_sync
                halign: "right"
                text_size: self.size

        Label:
            text: root.error_text
            color: 0.85, 0.25, 0.25, 1
            text_size: self.width, None
            halign: "left"
            valign: "top"
            size_hint_y: None
            height: max(self.texture_size[1], dp(20))

        Label:
            text: "Alerts"
            bold: True
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.45
            do_scroll_x: False

            Label:
                id: alert_list
                text: "No active alerts"
                text_size: self.width, None
                halign: "left"
                valign: "top"
                size_hint_y: None
                height: max(self.texture_size[1], self.parent.height)

        Label:
            text: "Devices"
            bold: True
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.35
            do_scroll_x: False

            Label:
                id: device_list
                text: "No devices"
                text_size: self.width, None
                halign: "left"
                valign: "top"
                size_hint_y: None
                height: max(self.texture_size[1], self.parent.height)

        BoxLayout:
            size_hint_y: None
            height: dp(44)
            spacing: dp(8)

            Button:
                text: "Refresh"
                on_release: app.refresh_now()

            Button:
                text: "Logout"
                on_release: app.logout()

<RootScreen>:
    LoginScreen:
    HomeScreen:
