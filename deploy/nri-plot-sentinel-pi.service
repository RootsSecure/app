[Unit]
Description=NRI Plot Sentinel Raspberry Pi Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/nri-plot-sentinel-pi
EnvironmentFile=/opt/nri-plot-sentinel-pi/.env
ExecStart=/usr/bin/python3 -m pi_client.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
