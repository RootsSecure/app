GATEWAY_BASE_URL=https://api.example.com
PI_PROVISIONING_TOKEN=replace-with-provisioning-token

# Optional. If omitted, a stable ID is derived from machine-id + MAC.
PI_HARDWARE_ID=

PI_VERIFY_TLS=true
PI_REQUEST_TIMEOUT_SECS=10
PI_LOG_LEVEL=INFO

PI_CLIENT_STATE_DIR=/var/lib/nri-plot-sentinel-pi
PI_SESSION_STATE_PATH=/var/lib/nri-plot-sentinel-pi/session_state.json
PI_QUEUE_DB_PATH=/var/lib/nri-plot-sentinel-pi/event_queue.sqlite3
PI_CAMERA_EVENTS_PATH=/var/lib/nri-plot-sentinel-pi/camera_events.jsonl

PI_HEARTBEAT_INTERVAL_SECS=60
PI_EVENT_FLUSH_INTERVAL_SECS=5
PI_EVENT_FLUSH_BATCH_SIZE=25
PI_QUEUE_MAX_BACKOFF_SECS=300

PI_CONNECT_RETRY_BASE_SECS=2
PI_CONNECT_RETRY_MAX_SECS=60
PI_SESSION_EXPIRY_SKEW_SECS=30

PI_NETWORK_CHECK_HOST=1.1.1.1
PI_NETWORK_CHECK_PORT=443
PI_NETWORK_CHECK_TIMEOUT_SECS=2
PI_CAMERA_POLL_INTERVAL_SECS=1

# JSON object values
PI_CONNECT_METADATA_JSON={"site":"home-town-plot","model":"raspberry-pi-5"}
PI_HEARTBEAT_METADATA_JSON={"camera":"pi-camera-v3","service":"nri-plot-sentinel-pi"}
